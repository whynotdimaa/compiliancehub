# App
DEBUG=true
SECRET_KEY=dev-secret-change-me

# PostgreSQL: app connects as non-superuser app_user (RLS applies);
# migrations run as the admin role (superusers bypass RLS)
DATABASE_URL=postgresql+asyncpg://app_user:app_password@postgres:5432/compliancehub
ALEMBIC_DATABASE_URL=postgresql+asyncpg://compliance:compliance@postgres:5432/compliancehub

# RabbitMQ
RABBITMQ_URL=amqp://compliance:compliance@rabbitmq:5672//

# Redis
REDIS_URL=redis://redis:6379/0

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=compliance123

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=compliance
MINIO_SECRET_KEY=compliance123
MINIO_BUCKET=documents

# LLM (OpenAI-compatible; for Ollama: LLM_BASE_URL=http://localhost:11434/v1)
LLM_BASE_URL=https://api.groq.com/openai/v1
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# External
TAVILY_API_KEY=
SLACK_WEBHOOK_URL=
